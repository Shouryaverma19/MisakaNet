#!/bin/bash
# 一键提交 lesson — 用法: ./submit-lesson <文件名或目录>
# 示例:
#   ./submit-lesson my-new-lesson.md
#   ./submit-lesson lessons/contrib/
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
cd "$REPO_DIR"

# 从 faq.md 读 PAT (本地桌面文件, 不在 git 仓库)
FAQ="/mnt/c/Users/hp/Desktop/自研/misakanet/FAQ.md"
if [ -f "$FAQ" ]; then
    PAT=$(grep "^ikalus" "$FAQ" | head -1 | cut -d'：' -f2 | tr -d ' ')
fi

if [ -z "$PAT" ]; then
    PAT="${GH_TOKEN}"
fi

if [ -z "$PAT" ]; then
    echo "❌ 未找到 PAT。请 export GH_TOKEN='<你的PAT>'"
    exit 1
fi

export GH_TOKEN="$PAT"

# 参数处理
TARGET="$1"
MSG=""
DRY=""

shift 2>/dev/null || true
for arg in "$@"; do
    case "$arg" in
        --message=*) MSG="${arg#*=}" ;;
        --dry-run) DRY="--dry-run" ;;
    esac
done

# 补全路径
if [[ "$TARGET" != /* ]] && [[ "$TARGET" != lessons/* ]]; then
    TARGET="lessons/contrib/$TARGET"
fi

echo "========================================"
echo "  📝 Lesson 提交工具"
echo "  目标: $TARGET"
echo "========================================"

CMD="python3 scripts/submit_lesson.py $TARGET $DRY"
if [ -n "$MSG" ]; then
    CMD="$CMD --message \"$MSG\""
fi

exec python3 scripts/submit_lesson.py "$TARGET" $( [ -n "$DRY" ] && echo "$DRY" ) $( [ -n "$MSG" ] && echo "--message" "$MSG" )
