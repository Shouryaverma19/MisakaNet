{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "misakanet",
  "compatibility_date": "2026-05-23",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "../docs"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      "binding": "MISAKANET_KV",
      "id": "YOUR_KV_NAMESPACE_ID"
    }
  ]
}
